# E2E Tests Value
# Copy this file to .env.test and fill in your values

# --- USERS TESTS ---
# GitHub username the current webbrowser is logged as
JD_E2E_USER=

# GitHub username that the current browser is not logged as, but that you trust
JD_E2E_SAFE_USER=
# ---

# --- ORG AND TEAM TESTS ---
# Name of a GitHub organization the user is a member of
JD_E2E_ORG=

# Name of an organization the user is not a member of, but that you trust
JD_E2E_SAFE_ORG=

# Name of a GitHub team within the organization that the user is a member of
JD_E2E_TEAM=

# Name of a GitHub team within the organization that the user is not a member of, but that you trust
JD_E2E_SAFE_TEAM=
# ---

